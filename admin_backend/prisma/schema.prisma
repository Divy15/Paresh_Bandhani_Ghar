// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/// 2. Role Master Table (Moved to top for clear relationship hierarchy)
model RoleMaster {
  roleId         Int              @id @default(autoincrement()) @map("roleid")
  roleName       String           @unique @map("rolename")
  createdAt      DateTime         @default(now()) @map("created_at")
  
  // Relations
  users          User[]
  rolePermissions RolePermission[]

  @@map("role_master")
}

/// 1. Admin Panel User Table
model User {
  id           Int        @id @default(autoincrement())
  firstName    String     @map("firstname")
  middleName   String?    @map("middlename") // Optional field
  lastName     String     @map("lastname")
  mobileNo     String     @unique @map("mobileno") // Unique constraint for identity
  roleId       Int        @map("roleid")
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  role         RoleMaster @relation(fields: [roleId], references: [roleId], onDelete: Restrict)

  @@map("user")
}

/// 3. Permission Master Table
model PermissionMaster {
  permissionId   Int              @id @default(autoincrement()) @map("permissionid")
  permissionName String           @unique @map("permissionname")
  createdAt      DateTime         @default(now()) @map("created_at")

  // Relations
  rolePermissions RolePermission[]

  @@map("permission_master")
}

/// 4. Role Permission Mapping Table (Join Table)
model RolePermission {
  id           Int              @id @default(autoincrement())
  roleId       Int              @map("roleid")
  permissionId Int              @map("permissionid")

  // Relations
  role         RoleMaster       @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  permission   PermissionMaster @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  // Composite unique constraint ensures a specific permission isn't added to a role twice
  @@unique([roleId, permissionId])
  @@map("role_permission")
}

model Media {
  id        Int      @id @default(autoincrement())
  path      String
  createdAt DateTime @default(now()) @map("created_at")

  // Inverse structural relations for Prisma queries
  categories    Category[]
  subcategories SubCategory[]

  @@map("media")
}

model Category {
  id           Int      @id @default(autoincrement())
  imageId      Int?     @map("image_id")
  categoryName String   @map("category_name")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationships
  media         Media?        @relation(fields: [imageId], references: [id], onDelete: SetNull)
  subcategories SubCategory[]

  @@map("category")
}

model SubCategory {
  id              Int      @id @default(autoincrement())
  categoryId      Int      @map("category_id")
  imageId         Int?     @map("image_id")
  subcategoryName String   @map("subcategory_name")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relationships
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  media    Media?   @relation(fields: [imageId], references: [id], onDelete: SetNull)

  @@map("subcategory")
}

model Material {
  id           Int      @id @default(autoincrement())
  materialName String   @map("material_name")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("material")
}

model ProductStructure {
  id        Int      @id @default(autoincrement())
  mainName  String   @map("main_name")
  includes  Json     // Native Postgres jsonb database column mapping arrays perfectly
  createdAt DateTime @default(now()) @map("created_at")

  @@map("product_structure")
}
